datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String    @id @default(cuid())
  email              String?   @unique
  name               String?
  avatarUrl          String?
  githubId           Int       @unique @default(0)
  githubUsername      String?
  role               String    @default("user")
  plan               String    @default("none")
  onboardingComplete Boolean   @default(false)
  orgName            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  projects           Project[]
}

model Project {
  id                  String               @id @default(cuid())
  userId              String
  name                String
  key                 String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports             RateLimitReport[]
  alertRules          AlertRule[]
  alertEvents         AlertEvent[]
  fallbackChain       FallbackChain?
  usageCredits        UsageCredit[]
  providerKeys        ProviderKey[]
  providerConnections ProviderConnection[]

  @@index([userId])
}

model RateLimitReport {
  id        String   @id @default(cuid())
  projectId String
  app       String   @default("default")
  provider  String
  model     String?
  timestamp DateTime
  limits    Json
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, timestamp])
  @@index([projectId, provider])
}

model AlertRule {
  id         String  @id @default(cuid())
  projectId  String
  provider   String?
  warnAt     Int     @default(70)
  criticalAt Int     @default(90)
  enabled    Boolean @default(true)
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, provider])
}

model AlertEvent {
  id         String   @id @default(cuid())
  projectId  String
  provider   String
  app        String
  metric     String
  threshold  Int
  current    Float
  limit      Float
  percentage Float
  timestamp  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, timestamp])
}

model FallbackChain {
  id        String  @id @default(cuid())
  projectId String  @unique
  chain     Json
  threshold Int     @default(80)
  enabled   Boolean @default(false)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProviderKey {
  id              String    @id @default(cuid())
  projectId       String
  provider        String
  encryptedKey    String
  label           String?
  status          String    @default("pending")
  lastValidatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, provider])
  @@index([projectId])
}

model ProviderConnection {
  id                String   @id @default(cuid())
  projectId         String
  provider          String
  status            String   @default("connected")
  lastPolledAt      DateTime?
  lastError         String?
  balance           Float?
  creditLimit       Float?
  periodSpend       Float?
  periodStart       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, provider])
  @@index([projectId])
}

model UsageCredit {
  id               String   @id @default(cuid())
  projectId        String
  provider         String
  app              String   @default("default")
  model            String?
  /// Total credit limit / balance ceiling (e.g. $100)
  creditsLimit     Float?
  /// Remaining credits at time of report
  creditsRemaining Float?
  /// Cost of the individual request that produced this snapshot
  requestCost      Float?
  timestamp        DateTime @default(now())
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, timestamp])
  @@index([projectId, provider])
}
