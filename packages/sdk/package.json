{
  "name": "@delimiter/sdk",
  "version": "0.1.0",
  "description": "Lightweight rate limit monitoring for AI APIs. Initialize once, monitor everything.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "rate-limit",
    "monitoring",
    "openai",
    "anthropic",
    "sdk",
    "observability"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/delimiterapp/delimiter",
    "directory": "packages/sdk"
  },
  "homepage": "https://delimiter.app",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8",
    "typescript": "^5"
  }
}
